{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and quiz results",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "description": "User's email" },
        "quizResult": { "type": "string", "description": "Result of the quiz" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" }
      },
      "required": ["uid", "name", "email"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "User" },
      "description": "User profiles and quiz data"
    }
  }
}
